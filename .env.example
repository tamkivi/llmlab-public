# Required to create the single admin account
ADMIN_EMAIL=
ADMIN_SETUP_CODE=
# Optional bearer token for operational admin API endpoints such as /api/db/audit.
# Keep separate from CRON_SECRET.
ADMIN_API_TOKEN=
# Required in production for persistent accounts/orders (recommended on Vercel Postgres/Neon/Supabase Postgres)
DATABASE_URL=
# Optional alternative Postgres URL name supported by the app
POSTGRES_URL=
# Hosted deployments fail closed without Postgres unless this is explicitly true. Do not use for production commerce.
ALLOW_EPHEMERAL_SQLITE=false
# Optional local/test SQLite data directory override
FART_PICKER_DATA_DIR=
# Use test keys in development/preview and live keys only in production.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
# Required for Vercel Cron authorization
CRON_SECRET=
ESTONIAN_PRICE_MAX_ITEMS=120
ESTONIAN_PRICE_CONCURRENCY=6
# Direct checkout requires fresh non-fallback pricing. Default is 24 and code caps overrides at 48.
DIRECT_CHECKOUT_PRICE_MAX_AGE_HOURS=24
# Display/diagnostic freshness threshold for trusted market rows.
TRUSTED_PRICE_MAX_AGE_HOURS=168
TRUSTED_PRICE_MIN_SAMPLES=1
